# =========================================================
# 🌟 UMIL 视频摘要项目专属 .gitignore
# =========================================================

# ---------------------------------------------------------
# 1. 原始数据集与视频 (体积极其庞大，绝对不能传)
# ---------------------------------------------------------
# 包含所有的 SumMe 和 TVSum 视频文件夹，以及官方的 h5 标签文件
data/
*.mp4
*.avi
*.webm
*.mkv
*.h5

# ---------------------------------------------------------
# 2. 训练输出与模型权重 (动辄几百MB的炼丹产物)
# ---------------------------------------------------------
# 你的训练脚本 main_umil.py 默认的输出文件夹
exp/
# 拦截所有可能的 PyTorch 权重文件 (例如 ckpt_epoch_49.pth, tvsum_best.pth)
*.pth
*.pt
*.ckpt

# ---------------------------------------------------------
# 3. 脚本自动生成的中间特征与标签
# ---------------------------------------------------------
# generate_labels_with_clip.py 跑出来的 multi-hot 字典文件
labels/*.npy
# 如果你希望把生成的 .txt 目录列表 (如 action_vocabulary.txt) 传上去，可以保留
# 如果不需要，可以取消下面这行的注释
# labels/

# ---------------------------------------------------------
# 4. 下载的本地开源大模型权重
# ---------------------------------------------------------
# 我们为了防断网，用 wget 手动下载的本地 CLIP 文件夹及模型文件
clip-vit-base-patch32/
*.bin

# ---------------------------------------------------------
# 5. Python 缓存与虚拟环境 (常规拦截)
# ---------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# 你的 Anaconda 或 venv 虚拟环境文件夹（假设你建在了项目里）
venv/
.env

# ---------------------------------------------------------
# 6. IDE 与操作系统自动生成的隐藏文件
# ---------------------------------------------------------
.vscode/
.idea/
.DS_Store
Thumbs.db